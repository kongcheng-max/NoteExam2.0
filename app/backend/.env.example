# NoteExam 环境变量配置
# 复制此文件为 .env 并填写实际值

# DeepSeek API (必填)
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# API 重试
MAX_RETRIES=2
API_TIMEOUT=120

# 百度 OCR (图片上传用，可选)
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 数据库 (开发用 SQLite，生产用 PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./noteexam.db

# 服务器
HOST=0.0.0.0
PORT=8000
